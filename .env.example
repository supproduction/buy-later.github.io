# Copy to .env.local and fill in. The app works fully WITHOUT these (local-only);
# they enable optional accounts + cross-device sync via Supabase.
# Both values are safe to expose in the frontend (the anon/publishable key is
# protected by Row-Level Security). NEVER put the database password here.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
